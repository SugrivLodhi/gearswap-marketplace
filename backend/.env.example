# Server Configuration
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/gearswap

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Redis (used by BullMQ job queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Worker Configuration
WORKER_EMAIL_CONCURRENCY=5

# Rate Limiting (all optional — shown values are defaults)
# Global: per-IP limit applied to every route
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW=900
# Auth: per-IP strict limit for login/register GraphQL mutations
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=900
# User: per-userId (JWT) limit for authenticated requests
RATE_LIMIT_USER_MAX=300
RATE_LIMIT_USER_WINDOW=900
# Fail-open: if true, allows requests through when Redis is unavailable
RATE_LIMIT_SKIP_ON_REDIS_ERROR=true

# Kafka (optional: enable when broker is available)
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=gearswap-api

# Search sync mode:
# - inline (default): API writes to Typesense directly
# - event: Search Indexer service updates Typesense from Kafka events
TYPESENSE_SYNC_MODE=inline

# Inventory reservation mode:
# - legacy: current in-process stock deduction
# - shadow: publish reservation request for observation, but still use legacy deduction
# - saga: reserve stock through Catalog service via Kafka reply
INVENTORY_RESERVATION_MODE=legacy
INVENTORY_RESERVATION_TIMEOUT_MS=8000
